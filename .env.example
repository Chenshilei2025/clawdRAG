# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Vision Model Configuration
VISION_PROVIDER=openai
VISION_MODEL=gpt-4o

# OCR Configuration
# Options: tesseract, openai
OCR_PROVIDER=tesseract
TESSERACT_PATH=/usr/bin/tesseract

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
IMAGE_EMBEDDING_MODEL=clip-ViT-B-32

# Vector Store Configuration
# Options: chroma, milvus, faiss
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=./workspace/vector_store
CHROMA_PERSIST_DIR=./workspace/vector_store/chroma

# Video Processing
VIDEO_FRAME_EXTRACTION_FPS=1
AUDIO_TRANSCRIPTION_MODEL=whisper-1

# Document Processing
PDF_PARSE_ENGINE=pdfplumber
PPT_PARSE_ENGINE=python-pptx

# Workspace Configuration
WORKSPACE_PATH=./workspace
MEMORY_PATH=./workspace/memory

# Session Configuration
SESSION_TIMEOUT_SECONDS=3600
MAX_CONTEXT_TOKENS=100000

# API Server (if running in API mode)
API_HOST=0.0.0.0
API_PORT=8000
